# Image Generation API Keys (optional — used by image_gen.py)
# At least one provider must be configured for AI image generation

# OpenAI / DALL-E
OPENAI_API_KEY=

# Stability AI
STABILITY_API_KEY=

# Replicate
REPLICATE_API_KEY=

# Local / self-hosted (e.g., ComfyUI)
IMAGE_GEN_PROVIDER=openai
IMAGE_GEN_MODEL=dall-e-3